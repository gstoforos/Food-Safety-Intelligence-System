# =============================================================================
# FSIS — Food Safety Intelligence System
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# --- Gemini API keys (FREE tier — 1500 req/day per key) ---
# Add as many as you have for rotation. Pipeline will round-robin and skip
# rate-limited keys automatically. Get free keys at: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI API key (PAID — gpt-4o-mini ~$0.005/recall reviewed) ---
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude API key (FREE $5 credit on signup) ---
# Optional. If empty, Claude review is skipped.
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- GitHub auto-commit (only needed for local runs; GitHub Actions auto-handles) ---
GH_TOKEN=
GIT_USER_EMAIL=fsis-bot@advfood.tech
GIT_USER_NAME=FSIS Bot

# --- Pipeline tuning ---
SINCE_DAYS=30           # Look-back window for scrapers
MAX_PARALLEL=8          # Parallel scraper threads
SKIP_AI=false           # If "true", disable Gemini enrichment (debug mode)
SKIP_REVIEW=false       # If "true", disable OpenAI/Claude review (debug mode)
SKIP_COMMIT=false       # If "true", don't push to GitHub (local testing)
